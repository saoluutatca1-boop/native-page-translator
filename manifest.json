{
  "manifest_version": 3,
  "name": "Native Page Translator VI / EN",
  "version": "4.2.0",
  "description": "Dịch toàn trang VI/EN và đổi tiếng Việt đang gõ thành tiếng Anh. Hỗ trợ nhiều API key: DeepL, Google AI Studio (Gemini), OpenAI-compatible, kèm fallback miễn phí.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "webNavigation",
    "contextMenus"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://translate.google.com/*",
    "https://api.mymemory.translated.net/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Native Translator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
